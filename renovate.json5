{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: ["config:recommended"],

  minimumReleaseAge: "3 days",

  packageRules: [
    {
      description: "Group npm package patch/minor updates into one PR.",
      matchManagers: ["npm"],
      matchUpdateTypes: ["patch", "minor"],
      matchJsonata: ["isBreaking != true"],
      groupName: "npm package patch/minor updates",
      groupSlug: "npm-package-patch-minor",
    },
    {
      description: "Group Cargo package patch/minor updates into one PR.",
      matchManagers: ["cargo"],
      matchUpdateTypes: ["patch", "minor"],
      matchJsonata: ["isBreaking != true"],
      groupName: "Cargo package patch/minor updates",
      groupSlug: "cargo-package-patch-minor",
    },
    {
      description: "Group binary version pins by binary name, without grouping different binaries together.",
      matchDepTypes: ["binary"],
      groupName: "{{{depName}}}",
      groupSlug: "binary-{{{depName}}}",
    },
  ],

  customManagers: [
    // Cargo-installed binaries pinned in [package.metadata.cargo-binaries].
    {
      customType: "jsonata",
      fileFormat: "toml",
      managerFilePatterns: ["/^Cargo\\.toml$/"],
      matchStrings: [
        '$each(package.metadata."cargo-binaries", function($version, $name) { {"depName": $name, "currentValue": $version} })',
      ],
      datasourceTemplate: "crate",
      versioningTemplate: "cargo",
      depTypeTemplate: "binary",
    },
    // ghalint version pinned in the GitHub Actions lint workflow.
    {
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/ci\\.yml$/"],
      matchStrings: [
        "GHALINT_VERSION:\\s*(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
      ],
      depNameTemplate: "suzuki-shunsuke/ghalint",
      datasourceTemplate: "github-releases",
      depTypeTemplate: "binary",
    },
  ],
}
